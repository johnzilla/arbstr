# arbstr node environment variables
# Copy to .env and fill in values: cp .env.example .env

# Vault internal API shared secret (required when vault is configured)
VAULT_INTERNAL_TOKEN=change-me-to-a-random-secret

# Cashu mint private key (auto-generated if not set)
MINT_PRIVATE_KEY=supersecretprivatekey

# Cashu payment rail threshold in millisatoshis (default: 1M msats = 1000 sats)
# Below threshold: Cashu (instant, zero fees). Above: Lightning (final settlement).
CASHU_THRESHOLD_MSAT=1000000

# Logging level for arbstr core
RUST_LOG=arbstr=info
